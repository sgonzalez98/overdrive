<?xml version="1.0" encoding="utf-8"?>
<!--
  RoadSense hazard action sheet — shown when the user taps a hazard pin on
  the map. Surfaces the hazard's type / severity / confidence / status and
  lets the user CONFIRM (human-verify, optionally correcting severity/type)
  or DELETE (reject) it. Inflated by RoadSenseMapActivity into a
  BottomSheetDialog themed Theme.Overdrive.M3.BottomSheet.

  The severity / type correction chip groups are single-select; the
  Activity pre-checks the chip matching the hazard's current value and
  reads back the selection on Confirm.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="18dp"
        android:background="@drawable/sheet_drag_handle" />

    <!-- Header: icon + type title + status chip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivHazardIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="14dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_hazard_unknown"
            app:tint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/tvHazardType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
            android:textColor="?attr/colorOnSurface"
            tools:ignore="HardcodedText"
            android:text="Pothole" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipStatus"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="false"
            android:clickable="false"
            android:focusable="false"
            app:chipStrokeWidth="0dp"
            app:chipBackgroundColor="?attr/colorSecondaryContainer"
            android:textColor="?attr/colorOnSecondaryContainer"
            tools:ignore="HardcodedText"
            android:text="Confirmed" />
    </LinearLayout>

    <!-- Meta line: severity · confidence · observations -->
    <TextView
        android:id="@+id/tvHazardMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        tools:ignore="HardcodedText"
        android:text="Moderate · 82% confidence · 3 reports" />

    <!-- Severity correction -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/roadsense_map_severity_label"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupSeverity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:singleLine="true"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSevMinor"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/roadsense_sev_minor" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSevModerate"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/roadsense_sev_moderate" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSevSevere"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/roadsense_sev_severe" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Type correction -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/roadsense_map_type_label"
        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:singleLine="true"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTypeBreaker"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/roadsense_type_breaker" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTypePothole"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/roadsense_type_pothole" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTypeRough"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/roadsense_type_rough" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTypeUnknown"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/roadsense_map_type_unknown" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHazardDelete"
            style="@style/Widget.Overdrive.M3.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="@string/roadsense_map_delete"
            android:textColor="?attr/colorError"
            app:strokeColor="?attr/colorError"
            app:iconTint="?attr/colorError" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHazardConfirm"
            style="@style/Widget.Overdrive.M3.Button.Tonal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/roadsense_map_confirm" />
    </LinearLayout>
</LinearLayout>
