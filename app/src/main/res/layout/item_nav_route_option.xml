<?xml version="1.0" encoding="utf-8"?>
<!--
  RoadSense map — one route-option row in the route-options bottom sheet,
  rendered by NavRouteOptionAdapter. Each row presents one candidate route:
    - a leading directions glyph in a tonal primary-container disc;
    - a TitleMedium label ("Route 1", "Route 2", …) with an optional
      "Fastest" hint chip;
    - a muted distance line and tidy hazards-along-route severity pills;
    - an ETA (large, prominent, primary) and a selected-row check on the right.
  The whole row is selectable; the host highlights the selected row by tinting
  its leading glyph + label and showing the check. All colours are theme attrs
  so it is correct in day + night.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:minHeight="72dp"
    android:orientation="horizontal"
    android:paddingHorizontal="20dp"
    android:paddingVertical="12dp">

    <ImageView
        android:id="@+id/ivRouteIcon"
        style="@style/Widget.Overdrive.NavRow.LeadingIcon.Route"
        android:layout_marginEnd="16dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_directions"
        app:tint="?attr/colorPrimary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvRouteLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/colorOnSurface"
                tools:text="Route 1" />

            <TextView
                android:id="@+id/tvRouteHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_route_hint_chip"
                android:fontFamily="sans-serif-medium"
                android:minHeight="20dp"
                android:gravity="center"
                android:letterSpacing="0.01"
                android:paddingHorizontal="9dp"
                android:paddingVertical="3dp"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="Fastest"
                tools:visibility="visible" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvRouteDistance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="12.4 km" />

        <!-- Hazards-along-route severity pills (severe / moderate / minor counts).
             Each pill is a small colored chip; hidden when its count is 0, and the
             whole row is GONE when the route has no hazards. -->
        <LinearLayout
            android:id="@+id/routeHazardPills"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/pillSevere"
                style="@style/Widget.Overdrive.HazardPill"
                android:background="@drawable/bg_hazard_pill_severe"
                android:drawablePadding="4dp"
                android:visibility="gone"
                tools:text="2 severe"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/pillModerate"
                style="@style/Widget.Overdrive.HazardPill"
                android:background="@drawable/bg_hazard_pill_moderate"
                android:visibility="gone"
                tools:text="3 moderate"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/pillMinor"
                style="@style/Widget.Overdrive.HazardPill"
                android:background="@drawable/bg_hazard_pill_minor"
                android:layout_marginEnd="0dp"
                android:visibility="gone"
                tools:text="1 minor"
                tools:visibility="visible" />

            <!-- Status pill: shown INSTEAD of severity pills when a route has no
                 hazard counts — "Clear" (mapped, no hazards) or "Not mapped yet"
                 (no RoadSense coverage in this corridor). Neutral surface chip. -->
            <TextView
                android:id="@+id/pillStatus"
                style="@style/Widget.Overdrive.HazardPill"
                android:background="@drawable/bg_route_status_pill"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone"
                tools:text="Not mapped yet"
                tools:visibility="visible" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvRouteEta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:fontFamily="sans-serif-medium"
        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
        android:textColor="?attr/colorPrimary"
        tools:text="18 min" />

    <ImageView
        android:id="@+id/ivRouteCheck"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginStart="12dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_check"
        android:visibility="invisible"
        app:tint="?attr/colorPrimary"
        tools:visibility="visible" />

</LinearLayout>
