<?xml version="1.0" encoding="utf-8"?>
<!--
  Recordings page — portrait. SOTA redesign matching events.html aesthetic.

  Vertical rhythm:
    1. Hero header
       ・ Title row: "Recordings" + tonal Settings (right-aligned).
       ・ Subtitle row: count chip pill ("12 today · 320 total · 42 GB")
         on a faint surface, reads like the events.html top bar's count
         strip.
    2. Filter strip — wrapped in a subtle surface container (events.html
       `.filter-tabs-row2` parity):
         ・ Segmented Dashcam / Surveillance with icons (running counts).
         ・ Date jump card (◀ Today / clip count ▶).
         ・ TYPE chips (Dashcam segment only).
         ・ WHAT chip row (Surveillance only).
         ・ SEVERITY chip row (Surveillance only) + Reset.
         ・ PLACE chip row (auto-hidden until any place is tagged).
    3. Library container — hosts the embedded RecordingLibraryFragment list.

  IDs preserved (consumed by RecordingsFragment.kt — DO NOT rename):
    segmentedSource, segmentDashcam, segmentSurveillance,
    btnRecordingsSettings, libraryContainer,
    btnPrevDay, btnNextDay, cardDateJump, tvSelectedDate, tvDayClipCount,
    chipActorAny, chipActorPerson, chipActorVehicle, chipActorBike,
    chipActorAnimal, chipSevAny, chipSevAlert, chipSevCritical,
    btnFilterReset, chipTypeNormal, chipTypeProximity, chipGroupPlace,
    rowTypeFilter, rowWhatFilter, rowSeverityFilter, rowPlaceFilter,
    btnClearDate, tvRecordingsSummary,
    cardPlaceSearch, etPlaceSearch, btnClearPlaceSearch (place substring search).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <!-- ============ Hero header ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/page_padding_top"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recordings_title"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />

            <!--
              Total-count badge next to the title. Reads like the small
              counter on events.html's top bar; populated by the parent's
              refreshCounts() executor. Hidden until the first scan lands
              so the title doesn't briefly flicker "0".
            -->
            <TextView
                android:id="@+id/tvTitleCountBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/recording_lib_count_pill"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:textColor="?attr/colorOnSurface"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="320"
                tools:visibility="visible" />

            <!-- spacer pushes Settings to the trailing edge -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecordingsSettings"
                style="@style/Widget.Material3.Button.TonalButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                android:contentDescription="@string/recordings_action_settings"
                android:text="@string/recordings_action_settings"
                android:textAllCaps="false"
                app:icon="@drawable/ic_settings"
                app:iconGravity="textStart" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvRecordingsSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="@string/recordings_summary_pending"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="12 today · 320 total · 42 GB" />
    </LinearLayout>

    <!-- ============ Top filter strip ============
         Wrapped in a subtle MaterialCardView so the chip rows read as a
         single coherent affordance rather than four loose horizontal
         scrollers, mirroring events.html's `.filter-tabs-row2` block.
    -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/page_padding_horizontal"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="@dimen/card_gap_vertical"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
        app:cardCornerRadius="@dimen/card_radius_standard"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

        <!-- Row 1: Dashcam | Surveillance segmented control -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/segmentedSource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:checkedButton="@id/segmentDashcam"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/segmentDashcam"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="@string/recordings_segment_dashcam"
                android:textAllCaps="false"
                app:icon="@drawable/ic_directions_car"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:iconPadding="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/segmentSurveillance"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="@string/recordings_segment_surveillance"
                android:textAllCaps="false"
                app:icon="@drawable/ic_sentry"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:iconPadding="6dp" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Row 1b: Free-text place search.
             Substring narrowing across short / medium / displayName place
             labels — routed through `placeContains=` on /api/recordings.
             Full-width on portrait because the title row is already
             saturated; the M3 surface treatment matches the date-jump
             card immediately below so they read as a coherent control
             stack. RecordingsFragment.setupPlaceSearch null-safely binds
             the same etPlaceSearch / btnClearPlaceSearch IDs as the
             landscape variant. -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPlaceSearch"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="6dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_events"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <EditText
                    android:id="@+id/etPlaceSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:background="@null"
                    android:hint="@string/recording_lib_place_search_hint"
                    android:imeOptions="actionSearch"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnClearPlaceSearch"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/cd_clear_date_filter"
                    android:padding="6dp"
                    android:src="@drawable/ic_clear"
                    android:visibility="gone"
                    app:tint="?attr/colorOnSurfaceVariant"
                    tools:visibility="visible" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Row 2: date jump (◀ card ▶) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:baselineAligned="false">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrevDay"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/cd_previous_day"
                app:icon="@drawable/ic_chevron_left"
                app:iconSize="22dp"
                app:iconTint="?attr/colorOnSurfaceVariant"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDateJump"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardElevation="0dp"
                app:cardCornerRadius="@dimen/card_radius_accent"
                app:rippleColor="?attr/colorPrimary"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_events"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/tvSelectedDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:singleLine="true"
                        android:ellipsize="end"
                        tools:text="Today" />

                    <TextView
                        android:id="@+id/tvDayClipCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="2dp"
                        android:background="@drawable/recording_lib_count_pill"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:visibility="gone"
                        tools:text="12 clips"
                        tools:visibility="visible" />

                    <ImageButton
                        android:id="@+id/btnClearDate"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginStart="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/cd_clear_date_filter"
                        android:padding="4dp"
                        android:src="@drawable/ic_clear"
                        android:visibility="gone"
                        app:tint="?attr/colorOnSurfaceVariant"
                        tools:visibility="visible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextDay"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/cd_next_day"
                app:icon="@drawable/ic_chevron_right"
                app:iconSize="22dp"
                app:iconTint="?attr/colorOnSurfaceVariant"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />
        </LinearLayout>

        <!-- Row 3a: TYPE chips (Dashcam segment only) -->
        <HorizontalScrollView
            android:id="@+id/rowTypeFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/recording_lib_filter_section_type"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"
                    app:singleLine="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTypeNormal"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_chip_type_normal" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTypeProximity"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_chip_type_proximity" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Row 3: WHAT chips -->
        <HorizontalScrollView
            android:id="@+id/rowWhatFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/recording_lib_filter_section_what"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupWhat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"
                    app:singleLine="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipActorAny"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_chip_any"
                        android:checked="true" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipActorPerson"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_chip_person" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipActorVehicle"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_chip_vehicle" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipActorBike"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_chip_bike" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipActorAnimal"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_chip_animal" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Row 4: SEVERITY chips + Reset -->
        <LinearLayout
            android:id="@+id/rowSeverityFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp"
            android:baselineAligned="false">

            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:overScrollMode="never">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="@string/recording_lib_filter_section_severity"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.06"
                        android:textAllCaps="true" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupSeverity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="6dp"
                        app:singleLine="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSevAny"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/recording_lib_chip_any"
                            android:checked="true" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSevAlert"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/recording_lib_chip_alert" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSevCritical"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/recording_lib_chip_critical" />
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </HorizontalScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterReset"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:text="@string/recording_lib_filter_reset"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:visibility="gone"
                android:minHeight="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- Row 5: PLACE chips. Dynamically populated from the visible
             scan's distinct place.short labels in descending count order,
             capped at MAX_PLACE_CHIPS. Hidden entirely when geocoding
             never tagged anything (empty available set) — legacy users
             see no extra chrome. -->
        <HorizontalScrollView
            android:id="@+id/rowPlaceFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/recording_lib_filter_section_place"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true" />

                <!-- ChipGroup is populated from Kotlin (chips are
                     user-place-specific so they can't be authored as
                     static resources). The "Any" chip is fixed but
                     attached programmatically alongside the data
                     chips so its order stays stable as the data
                     refreshes. -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPlace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"
                    app:singleLine="true" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Row 6: STORAGE chips. Narrow the library to one physical volume
             (Internal / SD card / USB). Clips already span every location in
             the index; this filters by where each clip actually landed (the
             per-clip storage badge shows the same tag). "Any" = all volumes.
             Applies to both the Dashcam and Surveillance segments. -->
        <HorizontalScrollView
            android:id="@+id/rowStorageFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/recording_lib_filter_section_storage"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupStorage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"
                    app:singleLine="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipStorageAny"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_chip_any"
                        android:checked="true" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipStorageInternal"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_storage_filter_internal" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipStorageSd"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_storage_filter_sd" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipStorageUsb"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_storage_filter_usb" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </HorizontalScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ============ Library list (fills remaining height) ============ -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/libraryContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
