<?xml version="1.0" encoding="utf-8"?>
<!-- Neutral status pill (Clear / Not mapped yet) for a route-option row.
     Outlined tonal chip so it reads as informational, not a severity warning. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="?attr/colorSurfaceContainerHighest" />
    <stroke android:width="1dp" android:color="?attr/colorOutlineVariant" />
    <corners android:radius="10dp" />
</shape>
