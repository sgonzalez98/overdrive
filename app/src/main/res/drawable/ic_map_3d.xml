    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="?attr/colorOnSurface">
    <!-- Isometric cube top face -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M12,2.6L19.5,6.9L12,11.2L4.5,6.9Z" />
    <!-- Left face -->
    <path
        android:fillColor="@android:color/white"
        android:fillAlpha="0.55"
        android:pathData="M4.5,6.9L12,11.2L12,19.8L4.5,15.5Z" />
    <!-- Right face -->
    <path
        android:fillColor="@android:color/white"
        android:fillAlpha="0.8"
        android:pathData="M19.5,6.9L12,11.2L12,19.8L19.5,15.5Z" />
