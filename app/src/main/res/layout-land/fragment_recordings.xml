<?xml version="1.0" encoding="utf-8"?>
<!--
  Recordings page — landscape. Two-pane: library list (left) + inline player
  pane (right). Filter strip identical to portrait so users get the same
  affordances on the BYD landscape head-unit. The filter rows pack onto
  multiple rows on landscape:
    Row A: title row + Settings (always full-width).
    Row B: segmented Dashcam | Surveillance + date jump card.
    Row C: TYPE chips (left half) · WHAT chips (right half).
           Only one of the two is visible per segment (Dashcam → Type,
           Surveillance → What); the other is GONE.
    Row D: SEVERITY chips (left half) · PLACE chips (right half) · Reset.

  IDs preserved (consumed by RecordingsFragment.kt):
    segmentedSource, segmentDashcam, segmentSurveillance,
    btnRecordingsSettings, libraryContainer, previewContainer, previewPlaceholder,
    btnPrevDay, btnNextDay, cardDateJump, tvSelectedDate, tvDayClipCount,
    chipActorAny, chipActorPerson, chipActorVehicle, chipActorBike, chipActorAnimal,
    chipSevAny, chipSevAlert, chipSevCritical, btnFilterReset,
    rowTypeFilter, rowWhatFilter, rowSeverityFilter, rowPlaceFilter,
    chipGroupType, chipTypeNormal, chipTypeProximity,
    chipGroupWhat, chipGroupSeverity, chipGroupPlace.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <!-- ============ Hero header ============ -->
    <LinearLayout
        android:id="@+id/heroHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/page_padding_top"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recordings_title"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvTitleCountBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/recording_lib_count_pill"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:textColor="?attr/colorOnSurface"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="320"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvRecordingsSummary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="@string/recordings_summary_pending"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="12 today · 320 total · 42 GB" />

            <!-- Free-text place search. Lives in the title row so it sits
                 next to the date card on the row below; debounced 300ms in
                 RecordingsFragment.setupPlaceSearch and pushed through
                 applyAll(placeContains=…). Landscape-only — portrait users
                 still rely on the chip row for place narrowing. -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPlaceSearch"
                android:layout_width="220dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="4dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_events"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <EditText
                        android:id="@+id/etPlaceSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@null"
                        android:hint="@string/recording_lib_place_search_hint"
                        android:imeOptions="actionSearch"
                        android:importantForAutofill="no"
                        android:inputType="text"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:textColor="?attr/colorOnSurface"
                        android:textColorHint="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/btnClearPlaceSearch"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/cd_clear_date_filter"
                        android:padding="6dp"
                        android:src="@drawable/ic_clear"
                        android:visibility="gone"
                        app:tint="?attr/colorOnSurfaceVariant"
                        tools:visibility="visible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecordingsSettings"
                style="@style/Widget.Material3.Button.TonalButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:contentDescription="@string/recordings_action_settings"
                android:text="@string/recordings_action_settings"
                android:textAllCaps="false"
                app:icon="@drawable/ic_settings"
                app:iconGravity="textStart" />
        </LinearLayout>
    </LinearLayout>

    <!-- ============ Top filter strip ============ -->
    <LinearLayout
        android:id="@+id/filterStrip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_padding_horizontal"
        android:paddingBottom="6dp">

        <!-- Row B: segmented control + date jump -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:baselineAligned="false">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/segmentedSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:checkedButton="@id/segmentDashcam"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/segmentDashcam"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/recordings_segment_dashcam"
                    android:textAllCaps="false"
                    app:icon="@drawable/ic_directions_car"
                    app:iconSize="16dp"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/segmentSurveillance"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/recordings_segment_surveillance"
                    android:textAllCaps="false"
                    app:icon="@drawable/ic_sentry"
                    app:iconSize="16dp"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrevDay"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:contentDescription="@string/cd_previous_day"
                app:icon="@drawable/ic_chevron_left"
                app:iconSize="22dp"
                app:iconTint="?attr/colorOnSurfaceVariant"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDateJump"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardElevation="0dp"
                app:cardCornerRadius="@dimen/card_radius_accent"
                app:rippleColor="?attr/colorPrimary"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="9dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_events"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/tvSelectedDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:singleLine="true"
                        android:ellipsize="end"
                        tools:text="Today" />

                    <TextView
                        android:id="@+id/tvDayClipCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:paddingHorizontal="9dp"
                        android:paddingVertical="2dp"
                        android:background="@drawable/recording_lib_count_pill"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:visibility="gone"
                        tools:text="12 clips"
                        tools:visibility="visible" />

                    <ImageButton
                        android:id="@+id/btnClearDate"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginStart="6dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/cd_clear_date_filter"
                        android:padding="4dp"
                        android:src="@drawable/ic_clear"
                        android:visibility="gone"
                        app:tint="?attr/colorOnSurfaceVariant"
                        tools:visibility="visible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextDay"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/cd_next_day"
                app:icon="@drawable/ic_chevron_right"
                app:iconSize="22dp"
                app:iconTint="?attr/colorOnSurfaceVariant"
                app:iconGravity="textStart"
                app:iconPadding="0dp" />
        </LinearLayout>

        <!-- Row C: TYPE + WHAT chips on a single line.
             Per-segment visibility is driven by RecordingsFragment.applyChipRowVisibility:
             Dashcam → Type visible / What gone; Surveillance → Type gone / What visible.
             The half (Type or What) shown for the active segment occupies its own
             1/2 weight slot — the sibling stays gone, so the row reads as
             "the active segment's chip row floating on the left half" with
             empty space on the right. Acceptable per design call. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:baselineAligned="false">

            <!-- LEFT half: TYPE chips (Dashcam segment only) -->
            <LinearLayout
                android:id="@+id/rowTypeFilter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:overScrollMode="never">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="@string/recording_lib_filter_section_type"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.06"
                            android:textAllCaps="true" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:chipSpacingHorizontal="6dp"
                            app:singleLine="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipTypeNormal"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/recording_lib_chip_type_normal" />
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipTypeProximity"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/recording_lib_chip_type_proximity" />
                        </com.google.android.material.chip.ChipGroup>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- RIGHT half: WHAT chips (Surveillance segment only) -->
            <LinearLayout
                android:id="@+id/rowWhatFilter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:overScrollMode="never">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:text="@string/recording_lib_filter_section_what"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.06"
                            android:textAllCaps="true" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupWhat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:chipSpacingHorizontal="6dp"
                            app:singleLine="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipActorAny"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/recording_lib_chip_any"
                                android:checked="true" />
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipActorPerson"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/recording_lib_chip_person" />
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipActorVehicle"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/recording_lib_chip_vehicle" />
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipActorBike"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/recording_lib_chip_bike" />
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipActorAnimal"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/recording_lib_chip_animal" />
                        </com.google.android.material.chip.ChipGroup>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </LinearLayout>

        <!-- Row D: SEVERITY + PLACE chips on a single line.
             Severity left half, Place right half. Severity row also hosts the
             trailing Reset button (kept here, not on the Type+What row, to
             match portrait's "Reset lives next to Severity" placement). -->
        <LinearLayout
            android:id="@+id/rowSeverityFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:baselineAligned="false">

            <!-- LEFT half: SEVERITY chips -->
            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:overScrollMode="never">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:text="@string/recording_lib_filter_section_severity"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.06"
                        android:textAllCaps="true" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupSeverity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="6dp"
                        app:singleLine="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSevAny"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/recording_lib_chip_any"
                            android:checked="true" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSevAlert"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/recording_lib_chip_alert" />
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSevCritical"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/recording_lib_chip_critical" />
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- RIGHT half: PLACE chips. Dynamically populated from the visible
                 scan's distinct place.short labels in descending count order,
                 capped at MAX_PLACE_CHIPS. Hidden entirely when geocoding
                 never tagged anything — legacy users see no extra chrome.
                 Mirrors the portrait layout's rowPlaceFilter so
                 RecordingsFragment.findViewById(R.id.rowPlaceFilter)
                 resolves on both orientations. -->
            <HorizontalScrollView
                android:id="@+id/rowPlaceFilter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="@string/recording_lib_filter_section_place"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.06"
                        android:textAllCaps="true" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupPlace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="6dp"
                        app:singleLine="true" />
                </LinearLayout>
            </HorizontalScrollView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilterReset"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:text="@string/recording_lib_filter_reset"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:visibility="gone"
                android:minHeight="32dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- STORAGE chips row — narrow to one physical volume (Internal / SD /
             USB). Mirrors the portrait layout's rowStorageFilter so the shared
             RecordingsFragment.setupChipFilters findViewById calls resolve on
             both orientations. -->
        <HorizontalScrollView
            android:id="@+id/rowStorageFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="@string/recording_lib_filter_section_storage"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupStorage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"
                    app:singleLine="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipStorageAny"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_chip_any"
                        android:checked="true" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipStorageInternal"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_storage_filter_internal" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipStorageSd"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_storage_filter_sd" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipStorageUsb"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/recording_lib_storage_filter_usb" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- ============ Two-pane body ============ -->
    <LinearLayout
        android:id="@+id/twoPaneBody"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/page_padding_horizontal"
        android:paddingBottom="@dimen/page_padding_bottom"
        android:baselineAligned="false">

        <!-- LEFT: library list -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/libraryContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="11" />

        <View
            android:id="@+id/paneSpacer"
            android:layout_width="@dimen/card_gap_vertical"
            android:layout_height="match_parent" />

        <!-- RIGHT: preview surface -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/previewCard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="9"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="@dimen/card_radius_hero"
            app:cardElevation="0dp">

            <FrameLayout
                android:id="@+id/previewContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/previewPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <ImageView
                        android:layout_width="@dimen/card_icon_hero"
                        android:layout_height="@dimen/card_icon_hero"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_play_circle"
                        app:tint="?attr/colorOnSurfaceVariant"
                        android:alpha="0.6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="@string/recordings_preview_placeholder_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center"
                        android:text="@string/recordings_preview_placeholder_body"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</LinearLayout>
