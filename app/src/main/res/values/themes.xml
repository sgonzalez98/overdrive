<?xml version="1.0" encoding="utf-8"?>
<!--
  Light/Dark themes for Overdrive live in themes_overdrive.xml as
  Theme.Overdrive.M3 (the manifest theme). This file holds only the
  shape appearances referenced by Widget.Overdrive.M3.* styles.
-->
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Shape Appearances — referenced by Widget.Overdrive.M3.* in themes_overdrive.xml. -->
    <style name="ShapeAppearance.Overdrive.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.Overdrive.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Top-rounded-only shape for the RoadSense route-options bottom sheet:
         28dp top corners, square bottom so it sits flush at the screen edge,
         matching the M3 bottom-sheet idiom. -->
    <style name="ShapeAppearance.Overdrive.RouteSheet" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- ===================================================================
         RoadSense map navigation surfaces — reusable list-row primitives.
         These keep the autocomplete dropdown + route-options sheet rows on a
         single, premium rhythm (Google-Maps-quality list items): a soft tonal
         leading-icon disc, consistent two-line type, and mini hazard chips.
         All colours resolve through ?attr tokens so they are correct in both
         day and night.
         =================================================================== -->

    <!-- Leading-icon disc for a nav list row (search results). A 40dp soft
         surface-container-high circle that centres a 22dp glyph, so the icon
         reads as a deliberate "place" affordance, not a floating symbol.
         parent="" so the dotted name is not treated as an implicit parent. -->
    <style name="Widget.Overdrive.NavRow.LeadingIcon" parent="">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:padding">9dp</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:background">@drawable/bg_nav_leading_icon</item>
    </style>

    <!-- Leading-icon disc for a route-option row — primary-container tinted so
         the directions glyph reads as a navigation accent. -->
    <style name="Widget.Overdrive.NavRow.LeadingIcon.Route" parent="Widget.Overdrive.NavRow.LeadingIcon">
        <item name="android:background">@drawable/bg_nav_leading_icon_primary</item>
    </style>

    <!-- Primary line of a nav list row: TitleSmall, on-surface. -->
    <style name="TextAppearance.Overdrive.NavRow.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Secondary line of a nav list row: BodySmall, muted on-surface-variant. -->
    <style name="TextAppearance.Overdrive.NavRow.Subtitle" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <!-- Mini hazard-count chip on a route-option row. Padding/size tuned so the
         three severity pills read as a tidy chip cluster, not loose labels.
         Background + text colour are set per-pill in the layout (fixed
         severity colours are intentional). -->
    <style name="Widget.Overdrive.HazardPill" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:minHeight">20dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingHorizontal">9dp</item>
        <item name="android:paddingVertical">3dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

</resources>
